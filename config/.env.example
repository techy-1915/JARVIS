# JARVIS Environment Variables
# Copy to .env and fill in real values

# JWT Secret Key (REQUIRED in production)
JARVIS_SECRET_KEY=change-me-in-production

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# API settings
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8000
JARVIS_DEBUG=false

# Logging
LOG_LEVEL=INFO

# Optional: ChromaDB for vector storage
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
